# Stress test - high thread counts and heavy workloads
[group('presets')]
stress:
    #!/usr/bin/env bash
    set -euo pipefail
    ts=$(date +%Y%m%d_%H%M%S)
    raw="out/raw_stress_${ts}.csv"
    csv="out/out_stress_${ts}.csv"
    mkdir -p out
    rm -f "$raw" "$csv"
    echo "=== Stress test ({{nruns}} runs) ==="
    for run in $(seq 1 {{nruns}}); do
        echo ""
        echo "--- run $run/{{nruns}} ---"
        just simple   16 10000000 --csv "$raw"
        just simple   16 10000000 --csv "$raw" --glibc
        just mixed    16 10000000 --csv "$raw"
        just mixed    16 10000000 --csv "$raw" --glibc
        just large    16 10000 --csv "$raw"
        just large    16 10000 --csv "$raw" --glibc
        just threadtest 16 100 50000 64 100 --csv "$raw"
        just threadtest 16 100 50000 64 100 --csv "$raw" --glibc
        just larson   32 100 1000 10 500 30 --csv "$raw"
        just larson   32 100 1000 10 500 30 --csv "$raw" --glibc
    done
    just _aggregate "$raw" "$csv"
    echo ""
    echo "Results: $csv"

# Larson sweep - vary chunks-per-thread and size ranges
[group('presets')]
larson-sweep threads="8" sleep="10":
    #!/usr/bin/env bash
    set -euo pipefail
    ts=$(date +%Y%m%d_%H%M%S)
    raw="out/raw_larson-sweep_${ts}.csv"
    csv="out/out_larson-sweep_${ts}.csv"
    mkdir -p out
    rm -f "$raw" "$csv"
    echo "=== Larson parameter sweep ({{nruns}} runs) ==="
    for run in $(seq 1 {{nruns}}); do
        echo ""
        echo "--- run $run/{{nruns}} ---"
        for cpt in 50 100 500 1000; do
            for minmax in "10 500" "64 64" "100 4000" "1000 8000"; do
                read -r mn mx <<< "$minmax"
                just larson {{threads}} 50 $cpt $mn $mx {{sleep}} --csv "$raw"
                just larson {{threads}} 50 $cpt $mn $mx {{sleep}} --csv "$raw" --glibc
            done
        done
    done
    just _aggregate "$raw" "$csv"
    echo ""
    echo "Results: $csv"

# Threadtest sweep - vary chunk sizes and work parameters
[group('presets')]
threadtest-sweep threads="8":
    #!/usr/bin/env bash
    set -euo pipefail
    ts=$(date +%Y%m%d_%H%M%S)
    raw="out/raw_threadtest-sweep_${ts}.csv"
    csv="out/out_threadtest-sweep_${ts}.csv"
    mkdir -p out
    rm -f "$raw" "$csv"
    echo "=== Threadtest parameter sweep ({{nruns}} runs) ==="
    for run in $(seq 1 {{nruns}}); do
        echo ""
        echo "--- run $run/{{nruns}} ---"
        for cs in 16 64 256 1024; do
            for w in 0 10 100 1000; do
                just threadtest {{threads}} 50 30000 $cs $w --csv "$raw"
                just threadtest {{threads}} 50 30000 $cs $w --csv "$raw" --glibc
            done
        done
    done
    just _aggregate "$raw" "$csv"
    echo ""
    echo "Results: $csv"
