# Stress test - high thread counts and heavy workloads
[group('presets')]
stress:
    #!/usr/bin/env bash
    set -euo pipefail
    csv="out/out_stress_$(date +%Y%m%d_%H%M%S).csv"
    mkdir -p out
    rm -f "$csv"
    echo "=== Stress test ==="
    echo ""
    just simple   16 10000000 --csv "$csv"
    just simple   16 10000000 --csv "$csv" --glibc
    echo ""
    just mixed    16 10000000 --csv "$csv"
    just mixed    16 10000000 --csv "$csv" --glibc
    echo ""
    just large    16 10000 --csv "$csv"
    just large    16 10000 --csv "$csv" --glibc
    echo ""
    just threadtest 16 100 50000 64 100 --csv "$csv"
    just threadtest 16 100 50000 64 100 --csv "$csv" --glibc
    echo ""
    just larson   32 100 1000 10 500 30 --csv "$csv"
    just larson   32 100 1000 10 500 30 --csv "$csv" --glibc

# Larson sweep - vary chunks-per-thread and size ranges
[group('presets')]
larson-sweep threads="8" sleep="10":
    #!/usr/bin/env bash
    set -euo pipefail
    csv="out/out_larson-sweep_$(date +%Y%m%d_%H%M%S).csv"
    mkdir -p out
    rm -f "$csv"
    echo "=== Larson parameter sweep ==="
    for cpt in 50 100 500 1000; do
        for minmax in "10 500" "64 64" "100 4000" "1000 8000"; do
            read -r mn mx <<< "$minmax"
            echo ""
            echo "--- chunks_per_thread=$cpt min=$mn max=$mx ---"
            just larson {{threads}} 50 $cpt $mn $mx {{sleep}} --csv "$csv"
            just larson {{threads}} 50 $cpt $mn $mx {{sleep}} --csv "$csv" --glibc
        done
    done

# Threadtest sweep - vary chunk sizes and work parameters
[group('presets')]
threadtest-sweep threads="8":
    #!/usr/bin/env bash
    set -euo pipefail
    csv="out/out_threadtest-sweep_$(date +%Y%m%d_%H%M%S).csv"
    mkdir -p out
    rm -f "$csv"
    echo "=== Threadtest parameter sweep ==="
    for cs in 16 64 256 1024; do
        for w in 0 10 100 1000; do
            echo ""
            echo "--- chunk_size=$cs work=$w ---"
            just threadtest {{threads}} 50 30000 $cs $w --csv "$csv"
            just threadtest {{threads}} 50 30000 $cs $w --csv "$csv" --glibc
        done
    done
