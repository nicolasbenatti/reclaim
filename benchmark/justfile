# reclaim allocator benchmark runner
# Usage: just --list

set dotenv-load := false
set quiet

root_dir    := justfile_directory() / ".."
build_dir   := root_dir / "build"
results_dir := justfile_directory() / "out"
timestamp   := `date +%Y%m%d_%H%M%S`
nruns       := "10"

# Build

# Build all benchmark binaries
build:
    make -C {{root_dir}} bench

# Clean build artifacts
clean:
    make -C {{root_dir}} clean

# Helpers

# Create results directory with timestamp
@_setup_results dir=results_dir:
    mkdir -p {{dir}}

# Run a single benchmark binary with arbitrary args, tee to optional logfile
[no-exit-message]
@_run bin +args="":
    {{build_dir}}/{{bin}} {{args}}

# Aggregate raw CSV (N runs per config) into final CSV with mean/stddev
[no-exit-message]
@_aggregate raw final:
    awk -f scripts/aggregate.awk {{raw}} > {{final}}

# Individual Benchmarks

# Run simple benchmark (fixed 128B allocs)
simple threads="4" iterations="1000000" *flags="":
    just _run bench_simple --threads {{threads}} --iterations {{iterations}} {{flags}}

# Run mixed benchmark (1-40KB variable allocs, 256 live objects)
mixed threads="4" iterations="1000000" *flags="":
    just _run bench_mixed --threads {{threads}} --iterations {{iterations}} {{flags}}

# Run large benchmark (5-25MB allocs, 20 live blocks)
large threads="4" iterations="1000" *flags="":
    just _run bench_malloc_large --threads {{threads}} --iterations {{iterations}} {{flags}}

# Run threadtest benchmark (chunked alloc/dealloc with work simulation)
threadtest threads="4" iterations="50" chunks="30000" chunk_size="64" work="0" *flags="":
    just _run bench_threadtest --threads {{threads}} --iterations {{iterations}} --chunks {{chunks}} --chunk-size {{chunk_size}} --work {{work}} {{flags}}

# Run larson benchmark (remote deallocation stress, time-bounded)
larson threads="4" iterations="50" chunks_per_thread="100" min_size="10" max_size="500" sleep="10" *flags="":
    just _run bench_larson --threads {{threads}} --iterations {{iterations}} --chunks-per-thread {{chunks_per_thread}} --min-size {{min_size}} --max-size {{max_size}} --sleep {{sleep}} {{flags}}

# Presets

# Quick smoke test - fast run of every benchmark with low iteration counts
[group('presets')]
quick:
    #!/usr/bin/env bash
    set -euo pipefail
    ts=$(date +%Y%m%d_%H%M%S)
    raw="out/raw_quick_${ts}.csv"
    csv="out/out_quick_${ts}.csv"
    mkdir -p out
    rm -f "$raw" "$csv"
    echo "=== Quick smoke test ({{nruns}} runs) ==="
    for run in $(seq 1 {{nruns}}); do
        echo ""
        echo "--- run $run/{{nruns}} ---"
        just simple   4 100000 --csv "$raw"
        just simple   4 100000 --csv "$raw" --glibc
        just mixed    4 100000 --csv "$raw"
        just mixed    4 100000 --csv "$raw" --glibc
        just large    4 100 --csv "$raw"
        just large    4 100 --csv "$raw" --glibc
        just threadtest 4 10 10000 64 0 --csv "$raw"
        just threadtest 4 10 10000 64 0 --csv "$raw" --glibc
        just larson   4 50 100 10 500 3 --csv "$raw"
        just larson   4 50 100 10 500 3 --csv "$raw" --glibc
    done
    just _aggregate "$raw" "$csv"
    echo ""
    echo "Results: $csv"

# Allocator scalability - run at increasing no. of threads
[group('presets')]
scalability iterations="500000":
    #!/usr/bin/env bash
    set -euo pipefail
    ts=$(date +%Y%m%d_%H%M%S)
    raw="out/raw_scalability_${ts}.csv"
    csv="out/out_scalability_${ts}.csv"
    mkdir -p out
    rm -f "$raw" "$csv"
    echo "=== Thread Scaling ({{nruns}} runs) ==="
    for run in $(seq 1 {{nruns}}); do
        echo ""
        echo "--- run $run/{{nruns}} ---"
        for t in 1 2 4 8 16 32 64; do
            just simple   $t {{iterations}} --csv "$raw"
            just simple   $t {{iterations}} --csv "$raw" --glibc
            just mixed    $t {{iterations}} --csv "$raw"
            just mixed    $t {{iterations}} --csv "$raw" --glibc
            just large    $t 500 --csv "$raw"
            just large    $t 500 --csv "$raw" --glibc
            just threadtest $t 50 30000 64 0 --csv "$raw"
            just threadtest $t 50 30000 64 0 --csv "$raw" --glibc
            just larson   $t 50 100 10 500 10 --csv "$raw"
            just larson   $t 50 100 10 500 10 --csv "$raw" --glibc
        done
    done
    just _aggregate "$raw" "$csv"
    echo ""
    echo "Results: $csv"

